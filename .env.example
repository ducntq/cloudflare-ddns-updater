# Cloudflare API Configuration
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ZONE_NAME=example.com
CF_RECORD_NAME=ddns.example.com
CF_AAAA_RECORD_NAME=ddns-v6.example.com

# Optional Settings (default: false)
CF_PROXIED=false

# Retry settings for IP detection
CF_RETRY_COUNT=3
CF_RETRY_DELAY=10

# Logging settings
CF_LOG_RETENTION_DAYS=7
